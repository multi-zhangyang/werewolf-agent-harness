# ============================================================
# Werewolf MAS 配置示例 —— 复制为 .env 并填入真实值
# 支持 OpenAI Chat Completions、OpenAI Responses API、Anthropic Messages。
# 字段名使用 WEREWOLF_ 前缀，避免与系统
# 现有的 ANTHROPIC_ / OPENAI_ 环境变量冲突。
# ============================================================

# openai: OpenAI Chat Completions 兼容接口(base_url + /chat/completions)
# openai_responses: OpenAI Responses API(base_url + /responses)
# anthropic: Anthropic Messages API(base_url + /v1/messages)
WEREWOLF_LLM_PROVIDER=openai
WEREWOLF_LLM_API_BASE=https://api.openai.com/v1
WEREWOLF_LLM_API_KEY=replace-with-your-api-key
WEREWOLF_LLM_MODEL=

WEREWOLF_LLM_TEMPERATURE=0.85
# OpenAI Chat/Responses:0 表示不传输出 token 上限字段。
# Anthropic Messages:0 表示使用项目兼容默认 max_tokens=8192（该协议要求此字段）。
WEREWOLF_LLM_MAX_TOKENS=0
# false:不发送 response_format，由 prompt 请求普通 JSON 后在本地解析。
# true:发送旧式 {"type":"json_object"}。显式 RESPONSE_FORMAT 优先于该开关。
WEREWOLF_LLM_USE_JSON_FORMAT=false
# 可选的标准 OpenAI response_format JSON；留空表示未配置。
# json_schema descriptor 会自动映射到 Chat Completions 或 Responses 的标准 wire shape。
WEREWOLF_LLM_RESPONSE_FORMAT=
WEREWOLF_LLM_TIMEOUT=180
WEREWOLF_LLM_CONCURRENCY=4
WEREWOLF_LLM_MAX_RETRIES=3

WEREWOLF_AGENT_DECISION_TIMEOUT=240
# 0 表示不设置共享阶段 deadline。
WEREWOLF_AGENT_PHASE_DEADLINE=0

WEREWOLF_HOST=127.0.0.1
WEREWOLF_PORT=8000
WEREWOLF_LOG_LEVEL=info
# 逗号分隔的 exact origins；只接受 http/https 的 scheme + host + 可选端口。
WEREWOLF_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:8000,http://localhost:8000
# 当前 token 通过显式 header/query 传递，不需要 cookie credentials。
WEREWOLF_CORS_ALLOW_CREDENTIALS=false
# Browser WebSocket upgrades must match the exact CORS origins above. Native
# clients without Origin are allowed locally; set false for a browser-only
# public deployment behind an explicit reverse-proxy policy.
WEREWOLF_WS_ALLOW_MISSING_ORIGIN=true

# 保留中的 waiting/running/terminal 房间总上限。容量满时创建接口返回 429。
WEREWOLF_MAX_ROOMS=64
# 终态房间无活动任务和连接后保留的秒数；0 禁用自动 TTL 清理。
WEREWOLF_TERMINAL_ROOM_TTL=3600
# 单局 wall-clock 时限；小于等于 0 表示禁用。
WEREWOLF_ROOM_TIMEOUT=900
# 单房间 event + decision transcript 的逻辑条目上限；超限时房间 fail-closed。
WEREWOLF_MAX_ROOM_EVIDENCE_ENTRIES=20000
# 单房间同时在线 WebSocket 上限；每个连接拥有独立 writer task 与有界队列。
WEREWOLF_MAX_WS_CLIENTS_PER_ROOM=256

# 单进程 REST/WS token buckets。capacity 是突发量，refill rate 是每秒补充量。
WEREWOLF_REST_RATE_LIMIT_CAPACITY=120
WEREWOLF_REST_RATE_LIMIT_REFILL_RATE=20
WEREWOLF_REST_RATE_LIMIT_KEY_TTL_SECONDS=900
WEREWOLF_REST_RATE_LIMIT_MAX_KEYS=10000
WEREWOLF_WS_RATE_LIMIT_CAPACITY=60
WEREWOLF_WS_RATE_LIMIT_REFILL_RATE=10
WEREWOLF_WS_RATE_LIMIT_KEY_TTL_SECONDS=900
WEREWOLF_WS_RATE_LIMIT_MAX_KEYS=10000

# 每个 run/room 的 provider transport-attempt 预算；0 表示该维度不限制。
# Token 预算只接受 provider 报告的 input+output usage；缺失 usage 会封锁该 scope。
WEREWOLF_PROVIDER_BUDGET_MAX_CALLS=0
WEREWOLF_PROVIDER_BUDGET_MAX_TOKENS=0
WEREWOLF_PROVIDER_BUDGET_MAX_SCOPES=10000
WEREWOLF_PROVIDER_BUDGET_MAX_INFLIGHT_RESERVATIONS=100000
WEREWOLF_PROVIDER_BUDGET_CLOSED_SCOPE_TTL_SECONDS=3600

WEREWOLF_HUMAN_TIMEOUT=90
