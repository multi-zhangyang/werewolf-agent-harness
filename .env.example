# ============================================================
# Werewolf MAS 配置示例 —— 复制为 .env 并填入真实值
# 支持 OpenAI Chat Completions、OpenAI Responses API、Anthropic Messages。
# 字段名使用 WEREWOLF_ 前缀，避免与系统
# 现有的 ANTHROPIC_ / OPENAI_ 环境变量冲突。
# ============================================================

# openai: OpenAI Chat Completions 兼容接口(base_url + /chat/completions)
# openai_responses: OpenAI Responses API(base_url + /responses)
# anthropic: Anthropic Messages API(base_url + /v1/messages)
WEREWOLF_LLM_PROVIDER=openai
WEREWOLF_LLM_API_BASE=https://api.openai.com/v1
WEREWOLF_LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WEREWOLF_LLM_MODEL=

WEREWOLF_LLM_TEMPERATURE=0.85
# OpenAI Chat/Responses:0 表示不传输出 token 上限字段。
# Anthropic Messages:0 表示使用后端默认 max_tokens。
WEREWOLF_LLM_MAX_TOKENS=0
WEREWOLF_LLM_TIMEOUT=180
WEREWOLF_LLM_CONCURRENCY=4
WEREWOLF_LLM_MAX_RETRIES=3

WEREWOLF_HOST=127.0.0.1
WEREWOLF_PORT=8000
WEREWOLF_LOG_LEVEL=info

WEREWOLF_HUMAN_TIMEOUT=90
WEREWOLF_AI_THINKING_VISIBLE=true
